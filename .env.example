# Copier en .env.local (hors git) et renseigner les secrets pour le dev.
# .env.example est committé : il documente les variables, sans valeurs sensibles.

# --- Secrets (NE JAMAIS committer de vraies valeurs) ---
# HMAC partagé entre web et game-server pour la route /api/internal/settlement (contrat §8)
SETTLEMENT_SECRET=change-me-dev-only
# Signature du cookie de session httpOnly côté web (contrat §7)
SESSION_SECRET=change-me-dev-only

# --- Réseau / ports ---
# Front + server functions TanStack Start
WEB_PORT=3000
# Websocket + Lobby API boardgame.io (Koa)
GAME_SERVER_PORT=8000
# URL du game-server consommée par le client web (multi ranked)
GAME_SERVER_URL=http://localhost:8000

# --- Données ---
# Fichier SQLite côté web (better-sqlite3), créé/migré au boot
DATABASE_PATH=./data/pazaak.db
